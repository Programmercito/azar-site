---
// Tool: Sorteo de Personas
---

<div id="tool-sorteo"
     class="spotlight-card relative bg-card border border-gold/10 rounded-sm p-8 md:p-10 overflow-hidden transition-all duration-300 hover:border-gold/30 hover:-translate-y-1">

  <!-- Tool header -->
  <div class="flex items-start justify-between mb-8">
    <div>
      <div class="font-mono text-[10px] tracking-[0.2em] uppercase text-muted mb-2">01 — Sorteo</div>
      <h3 class="font-display text-4xl md:text-5xl text-prim tracking-wide">SORTEO</h3>
      <p class="font-serif italic text-sec text-lg mt-1">De personas y grupos</p>
    </div>
    <div class="text-4xl opacity-60 select-none">🎲</div>
  </div>

  <!-- Participants input -->
  <div class="mb-6">
    <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">
      Participantes (uno por línea)
    </label>
    <textarea id="sorteo-participants"
              class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm p-4 rounded-sm outline-none resize-none focus:border-gold/35 transition-colors duration-200 placeholder:text-muted"
              rows="5"
              placeholder="Juan&#10;María&#10;Carlos&#10;Ana&#10;Pedro"></textarea>
  </div>

  <!-- Options row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">
        Ganadores: <span id="sorteo-count-val" class="text-gold">1</span>
      </label>
      <input type="range" id="sorteo-count" min="1" max="10" value="1"
             class="w-full" />
    </div>
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">
        Modo de selección
      </label>
      <select id="sorteo-mode"
              class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-4 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200">
        <option value="single">Un ganador</option>
        <option value="multi">Múltiples ganadores</option>
        <option value="order">Orden aleatorio completo</option>
      </select>
    </div>
  </div>

  <!-- Result area -->
  <div id="sorteo-result"
       class="min-h-[80px] bg-void/60 border border-gold/8 rounded-sm p-5 mb-6 flex items-center justify-center">
    <span class="font-mono text-xs text-muted">Los ganadores aparecerán aquí</span>
  </div>

  <!-- CTA -->
  <button id="sorteo-btn" data-hover
          class="w-full font-mono text-xs tracking-[0.15em] uppercase bg-gold text-void py-4 rounded-sm font-medium hover:bg-amber transition-colors duration-200 active:scale-[0.99]"
          style="transition: background .2s, box-shadow .3s;"
          onmouseenter="this.style.boxShadow='0 0 25px rgba(212,168,67,.3)'"
          onmouseleave="this.style.boxShadow='none'">
    ⟆ Realizar Sorteo
  </button>
</div>

<script>
  const countInput = document.getElementById('sorteo-count') as HTMLInputElement;
  const countVal   = document.getElementById('sorteo-count-val')!;
  const modeSelect = document.getElementById('sorteo-mode') as HTMLSelectElement;
  const textarea   = document.getElementById('sorteo-participants') as HTMLTextAreaElement;
  const resultDiv  = document.getElementById('sorteo-result')!;
  const btn        = document.getElementById('sorteo-btn')!;

  countInput.addEventListener('input', () => {
    countVal.textContent = countInput.value;
  });

  btn.addEventListener('click', () => {
    const azarRandom = (window as any).azarRandom as () => number;
    const lines = textarea.value.split('\n').map(s => s.trim()).filter(Boolean);
    if (lines.length === 0) {
      resultDiv.innerHTML = `<span class="font-mono text-xs text-crimson">⚠ Agrega participantes primero</span>`;
      return;
    }

    const mode    = modeSelect.value;
    const count   = Math.min(parseInt(countInput.value), lines.length);
    const pool    = [...lines];

    // Fisher-Yates shuffle using entropy RNG
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(azarRandom() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }

    let winners: string[];
    if (mode === 'order') {
      winners = pool;
    } else {
      winners = pool.slice(0, count);
    }

    // Animate result
    resultDiv.innerHTML = '';
    if (mode === 'order') {
      resultDiv.innerHTML = `
        <ol class="w-full space-y-2">
          ${winners.map((w, i) => `
            <li class="flex items-center gap-3 font-mono text-sm animate-float-up" style="animation-delay:${i*60}ms">
              <span class="text-muted text-xs w-6 text-right">${i+1}.</span>
              <span class="${i === 0 ? 'text-amber font-medium' : 'text-prim'}">${w}</span>
              ${i === 0 ? '<span class="text-[10px] text-gold border border-gold/20 px-2 py-0.5 rounded-sm ml-auto">GANADOR</span>' : ''}
            </li>
          `).join('')}
        </ol>`;
    } else if (count === 1) {
      resultDiv.innerHTML = `
        <div class="text-center animate-float-up">
          <div class="font-display text-5xl text-amber mb-1" style="text-shadow:0 0 20px rgba(245,200,66,.4)">${winners[0]}</div>
          <div class="font-mono text-[10px] text-muted tracking-widest uppercase">🎉 Ganador</div>
        </div>`;
    } else {
      resultDiv.innerHTML = `
        <div class="w-full space-y-2">
          ${winners.map((w, i) => `
            <div class="flex items-center gap-3 animate-float-up" style="animation-delay:${i*80}ms">
              <span class="font-mono text-[10px] text-gold border border-gold/20 w-6 h-6 flex items-center justify-center rounded-sm shrink-0">${i+1}</span>
              <span class="font-serif text-lg text-prim">${w}</span>
            </div>
          `).join('')}
        </div>`;
    }
  });

  // Spotlight effect
  const card = document.getElementById('tool-sorteo')!;
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
    card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100).toFixed(1) + '%');
  });
</script>
