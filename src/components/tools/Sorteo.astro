---
// Tool: Sorteo de Personas — interfaz limpia y coherente
---

<div id="tool-sorteo" class="spotlight-card bg-card border border-gold/10 rounded-sm p-6 sm:p-8 transition-all duration-300 hover:border-gold/25">

  <!-- Participants input -->
  <div class="mb-6">
    <label class="font-mono text-[10px] tracking-[.18em] uppercase text-muted block mb-2">
      Participantes <span class="text-gold/60">(uno por línea)</span>
    </label>
    <textarea id="sorteo-participants"
              class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm p-4 rounded-sm outline-none resize-none focus:border-gold/35 transition-colors duration-200 placeholder:text-muted leading-relaxed"
              rows="5"
              placeholder="Juan&#10;María&#10;Carlos&#10;Ana&#10;Pedro"></textarea>
    <p id="sorteo-count-msg" class="font-mono text-[10px] text-muted mt-1.5">0 participantes</p>
  </div>

  <!-- Ganadores slider — único control -->
  <div class="mb-6 bg-elevated/40 border border-gold/8 rounded-sm p-5">
    <div class="flex justify-between items-center mb-4">
      <span class="font-mono text-[10px] tracking-[.18em] uppercase text-muted">Ganadores</span>
      <span id="sorteo-qty-display"
            class="font-display text-4xl text-gold leading-none"
            style="text-shadow: 0 0 20px rgba(212,168,67,.3)">1</span>
    </div>
    <input type="range" id="sorteo-count" min="1" max="20" value="1" />
    <div class="flex justify-between font-mono text-[9px] text-muted mt-1.5">
      <span>1 ganador</span>
      <span id="sorteo-mode-hint" class="text-gold/60">Selección simple</span>
      <span>20</span>
    </div>
  </div>

  <!-- Opción: mostrar orden completo (solo aparece si qty > 1) -->
  <div id="sorteo-order-row" class="hidden items-center gap-3 mb-6">
    <button id="sorteo-order-toggle" data-hover role="switch" aria-checked="false"
            class="relative w-10 h-5 rounded-full bg-elevated border border-gold/15 shrink-0 transition-colors duration-200">
      <span id="sorteo-order-thumb"
            class="absolute left-0.5 top-0.5 w-4 h-4 rounded-full bg-muted transition-all duration-200"></span>
    </button>
    <span class="font-mono text-[11px] text-sec">Mostrar orden aleatorio completo</span>
  </div>

  <!-- Result -->
  <div id="sorteo-result"
       class="min-h-[80px] bg-void/60 border border-gold/8 rounded-sm p-5 mb-5 flex items-center justify-center">
    <span class="font-mono text-[11px] text-muted">Los resultados aparecerán aquí</span>
  </div>

  <button id="sorteo-btn" data-hover
          class="w-full font-mono text-[11px] tracking-[.15em] uppercase bg-gold text-void py-4 rounded-sm font-medium hover:bg-amber transition-colors duration-200 active:scale-[.99] touch-manipulation"
          onmouseenter="this.style.boxShadow='0 0 24px rgba(212,168,67,.3)'"
          onmouseleave="this.style.boxShadow='none'">
    ⟆ Realizar Sorteo
  </button>
</div>

<script>
  const textarea   = document.getElementById('sorteo-participants') as HTMLTextAreaElement;
  const countInput = document.getElementById('sorteo-count') as HTMLInputElement;
  const qtyDisplay = document.getElementById('sorteo-qty-display')!;
  const modeHint   = document.getElementById('sorteo-mode-hint')!;
  const countMsg   = document.getElementById('sorteo-count-msg')!;
  const orderRow   = document.getElementById('sorteo-order-row')!;
  const orderBtn   = document.getElementById('sorteo-order-toggle')!;
  const orderThumb = document.getElementById('sorteo-order-thumb')!;
  const resultDiv  = document.getElementById('sorteo-result')!;
  const btn        = document.getElementById('sorteo-btn')!;

  let showFullOrder = false;

  // Update participant count
  textarea.addEventListener('input', () => {
    const n = textarea.value.split('\n').map(s => s.trim()).filter(Boolean).length;
    countMsg.textContent = `${n} participante${n !== 1 ? 's' : ''}`;
    countInput.max = String(Math.max(n, 1));
  });

  // Slider updates
  countInput.addEventListener('input', () => {
    const v = parseInt(countInput.value);
    qtyDisplay.textContent = String(v);
    if (v === 1) {
      modeHint.textContent = 'Selección simple';
      orderRow.classList.add('hidden');
      orderRow.classList.remove('flex');
    } else {
      modeHint.textContent = `${v} ganadores`;
      orderRow.classList.remove('hidden');
      orderRow.classList.add('flex');
    }
  });

  // Full order toggle
  orderBtn.addEventListener('click', () => {
    showFullOrder = !showFullOrder;
    orderBtn.setAttribute('aria-checked', String(showFullOrder));
    orderBtn.style.background    = showFullOrder ? 'var(--color-gold)' : '';
    orderThumb.style.transform   = showFullOrder ? 'translateX(20px)' : '';
    orderThumb.style.background  = showFullOrder ? 'var(--color-void)' : '';
  });

  btn.addEventListener('click', () => {
    const azarRandom = (window as any).azarRandom as () => number;
    const lines = textarea.value.split('\n').map(s => s.trim()).filter(Boolean);
    if (lines.length === 0) {
      resultDiv.innerHTML = `<span class="font-mono text-[11px] text-crimson">⚠ Agrega participantes primero</span>`;
      return;
    }

    const count = Math.min(parseInt(countInput.value), lines.length);
    const pool  = [...lines];

    // Fisher-Yates
    for (let i = pool.length - 1; i > 0; i--) {
      const j = Math.floor(azarRandom() * (i + 1));
      [pool[i], pool[j]] = [pool[j], pool[i]];
    }

    const display = showFullOrder ? pool : pool.slice(0, count);

    if (count === 1 && !showFullOrder) {
      resultDiv.innerHTML = `
        <div class="text-center animate-float-up">
          <div class="font-display text-5xl sm:text-6xl text-amber mb-2 leading-none"
               style="text-shadow:0 0 25px rgba(245,200,66,.4)">${display[0]}</div>
          <div class="font-mono text-[9px] tracking-widest uppercase text-muted mt-2">🎉 Ganador</div>
        </div>`;
    } else {
      resultDiv.innerHTML = `
        <ol class="w-full space-y-2">
          ${display.map((w, i) => `
            <li class="flex items-center gap-3 animate-float-up py-1"
                style="animation-delay:${i * 50}ms; border-bottom: 1px solid rgba(212,168,67,0.06);">
              <span class="font-mono text-[9px] text-muted w-5 shrink-0 text-right">${i + 1}</span>
              <span class="font-serif text-lg ${i < count ? 'text-prim' : 'text-muted'}">${w}</span>
              ${i === 0 ? `<span class="ml-auto font-mono text-[8px] tracking-widest uppercase border border-gold/25 text-gold px-2 py-0.5 rounded-sm shrink-0">ganador</span>` : ''}
              ${i > 0 && i < count && !showFullOrder ? `<span class="ml-auto font-mono text-[8px] text-muted shrink-0">#${i+1}</span>` : ''}
            </li>
          `).join('')}
        </ol>`;
    }
  });
</script>
