---
// Tool: Dados — grandes, con pips reales y animación
// NOTE: <style is:global> is required because dice HTML is injected via innerHTML
// and Astro's scoped CSS doesn't apply to dynamically created elements.
---

<div id="tool-dados" class="spotlight-card bg-card border border-gold/10 rounded-sm p-6 sm:p-8 transition-all duration-300 hover:border-gold/25">

  <!-- Options row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div>
      <label class="font-mono text-[10px] tracking-[.18em] uppercase text-muted block mb-2">
        Cantidad: <span id="dados-qty-val" class="text-gold">2</span>
      </label>
      <input type="range" id="dados-qty" min="1" max="10" value="2" />
    </div>
    <div>
      <label class="font-mono text-[10px] tracking-[.18em] uppercase text-muted block mb-2">Tipo de dado</label>
      <select id="dados-type"
              class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-3 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200">
        <option value="6">D6 — Estándar</option>
        <option value="4">D4 — Tetraedro</option>
        <option value="8">D8 — Octaedro</option>
        <option value="10">D10 — Decaedro</option>
        <option value="12">D12 — Dodecaedro</option>
        <option value="20">D20 — Icosaedro</option>
        <option value="100">D100 — Percentil</option>
        <option value="custom">Personalizado</option>
      </select>
    </div>
  </div>

  <!-- Custom range -->
  <div id="custom-range-row" class="hidden grid-cols-2 gap-4 mb-6">
    <div>
      <label class="font-mono text-[10px] tracking-[.18em] uppercase text-muted block mb-2">Mínimo</label>
      <input type="number" id="dados-min" value="1"
             class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-3 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200" />
    </div>
    <div>
      <label class="font-mono text-[10px] tracking-[.18em] uppercase text-muted block mb-2">Máximo</label>
      <input type="number" id="dados-max" value="100"
             class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-3 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200" />
    </div>
  </div>

  <!-- Dice display -->
  <div id="dados-result"
       class="min-h-[200px] flex flex-wrap items-center justify-center gap-5 p-6 mb-5 bg-void/40 border border-gold/8 rounded-sm">
    <span class="font-mono text-[11px] text-muted">Lanza para ver los dados</span>
  </div>

  <!-- Total -->
  <div class="flex items-center justify-between bg-elevated/50 border border-gold/8 rounded-sm px-5 py-3 mb-5">
    <span class="font-mono text-[10px] tracking-widest uppercase text-muted">Suma total</span>
    <span id="dados-sum" class="font-display text-4xl text-gold" style="text-shadow:0 0 15px rgba(212,168,67,.3)">—</span>
  </div>

  <button id="dados-btn" data-hover
          class="w-full font-mono text-[11px] tracking-[.15em] uppercase bg-gold text-void py-4 rounded-sm font-medium hover:bg-amber transition-colors duration-200 active:scale-[.99] touch-manipulation"
          onmouseenter="this.style.boxShadow='0 0 24px rgba(212,168,67,.3)'"
          onmouseleave="this.style.boxShadow='none'">
    ◈ Lanzar Dados
  </button>
</div>

<!-- is:global required — dice HTML injected via innerHTML won't get Astro scope attrs -->
<style is:global>
  /* ─── D6: pip positions via absolute layout ──────────────────── */
  .azar-die-d6 {
    position: relative;
    width: 96px; height: 96px;
    background: linear-gradient(145deg, #1d1d38, #111128);
    border: 2px solid rgba(212,168,67,.4);
    border-radius: 16px;
    box-shadow:
      0 0 0 1px rgba(212,168,67,.12),
      0 10px 36px rgba(0,0,0,.55),
      inset 0 1px 0 rgba(255,255,255,.07),
      0 0 24px rgba(212,168,67,.14);
    flex-shrink: 0;
    transition: transform .18s ease, box-shadow .3s ease;
  }
  .azar-die-d6:hover {
    transform: translateY(-5px) rotate(3deg) scale(1.05);
    box-shadow: 0 0 0 1px rgba(212,168,67,.25), 0 18px 44px rgba(0,0,0,.6), 0 0 40px rgba(212,168,67,.22);
  }

  /* Pip dot */
  .azar-pip {
    position: absolute;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #ffe080, #d4a843);
    box-shadow: 0 0 7px rgba(245,200,66,.8), 0 0 16px rgba(245,200,66,.35);
    transform: translate(-50%, -50%);
  }

  /* ─── Pip positions: (left%, top%) per value ─── */
  /* 1 */
  .azar-die-d6[data-val="1"] .azar-pip:nth-child(1) { left:50%; top:50%; }
  /* 2 */
  .azar-die-d6[data-val="2"] .azar-pip:nth-child(1) { left:72%; top:28%; }
  .azar-die-d6[data-val="2"] .azar-pip:nth-child(2) { left:28%; top:72%; }
  /* 3 */
  .azar-die-d6[data-val="3"] .azar-pip:nth-child(1) { left:72%; top:28%; }
  .azar-die-d6[data-val="3"] .azar-pip:nth-child(2) { left:50%; top:50%; }
  .azar-die-d6[data-val="3"] .azar-pip:nth-child(3) { left:28%; top:72%; }
  /* 4 */
  .azar-die-d6[data-val="4"] .azar-pip:nth-child(1) { left:28%; top:28%; }
  .azar-die-d6[data-val="4"] .azar-pip:nth-child(2) { left:72%; top:28%; }
  .azar-die-d6[data-val="4"] .azar-pip:nth-child(3) { left:28%; top:72%; }
  .azar-die-d6[data-val="4"] .azar-pip:nth-child(4) { left:72%; top:72%; }
  /* 5 */
  .azar-die-d6[data-val="5"] .azar-pip:nth-child(1) { left:28%; top:28%; }
  .azar-die-d6[data-val="5"] .azar-pip:nth-child(2) { left:72%; top:28%; }
  .azar-die-d6[data-val="5"] .azar-pip:nth-child(3) { left:50%; top:50%; }
  .azar-die-d6[data-val="5"] .azar-pip:nth-child(4) { left:28%; top:72%; }
  .azar-die-d6[data-val="5"] .azar-pip:nth-child(5) { left:72%; top:72%; }
  /* 6 */
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(1) { left:28%; top:22%; }
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(2) { left:72%; top:22%; }
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(3) { left:28%; top:50%; }
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(4) { left:72%; top:50%; }
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(5) { left:28%; top:78%; }
  .azar-die-d6[data-val="6"] .azar-pip:nth-child(6) { left:72%; top:78%; }

  /* ─── Non-D6: polygon shape with big number ─── */
  .azar-die-poly {
    width: 96px; height: 96px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 2px;
    background: linear-gradient(145deg, #1d1d38, #111128);
    border: 2px solid rgba(212,168,67,.35);
    border-radius: 8px;
    box-shadow:
      0 0 0 1px rgba(212,168,67,.1),
      0 10px 36px rgba(0,0,0,.55),
      0 0 22px rgba(212,168,67,.12);
    flex-shrink: 0;
    position: relative;
    transition: transform .18s ease, box-shadow .3s ease;
    overflow: hidden;
  }
  .azar-die-poly::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 25%, rgba(212,168,67,.08), transparent 65%);
    pointer-events: none;
  }
  .azar-die-poly:hover {
    transform: translateY(-5px) rotate(-3deg) scale(1.05);
    box-shadow: 0 0 0 1px rgba(212,168,67,.22), 0 18px 44px rgba(0,0,0,.6), 0 0 35px rgba(212,168,67,.2);
  }
  .azar-die-poly .azar-die-type {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: .18em;
    color: rgba(212,168,67,.55);
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .azar-die-poly .azar-die-value {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--color-amber);
    text-shadow: 0 0 18px rgba(245,200,66,.55), 0 0 40px rgba(245,200,66,.2);
    position: relative;
    z-index: 1;
  }

  /* ─── Enter animation ─── */
  @keyframes azar-die-enter {
    from { opacity: 0; transform: scale(.5) rotate(-20deg); }
    to   { opacity: 1; transform: scale(1)  rotate(0deg); }
  }
  .azar-die-enter {
    animation: azar-die-enter .4s cubic-bezier(.34,1.56,.64,1) both;
  }
</style>

<script>
  const qtyInput   = document.getElementById('dados-qty') as HTMLInputElement;
  const qtyVal     = document.getElementById('dados-qty-val')!;
  const typeSelect = document.getElementById('dados-type') as HTMLSelectElement;
  const customRow  = document.getElementById('custom-range-row')!;
  const minInput   = document.getElementById('dados-min') as HTMLInputElement;
  const maxInput   = document.getElementById('dados-max') as HTMLInputElement;
  const resultDiv  = document.getElementById('dados-result')!;
  const sumEl      = document.getElementById('dados-sum')!;
  const btn        = document.getElementById('dados-btn')!;

  qtyInput.addEventListener('input', () => { qtyVal.textContent = qtyInput.value; });

  typeSelect.addEventListener('change', () => {
    const isCustom = typeSelect.value === 'custom';
    customRow.classList.toggle('hidden', !isCustom);
    customRow.classList.toggle('grid',    isCustom);
  });

  // Build a D6 with absolute-positioned pip dots
  function buildD6(val: number, delay: number): string {
    const pips = Array.from({ length: val }, () => `<span class="azar-pip"></span>`).join('');
    return `<div class="azar-die-d6 azar-die-enter" data-val="${val}"
                 style="animation-delay:${delay}ms" title="D6: ${val}">${pips}</div>`;
  }

  // Build a non-D6 with large number
  function buildDPoly(val: number, faces: number, delay: number): string {
    return `<div class="azar-die-poly azar-die-enter"
                 style="animation-delay:${delay}ms" title="D${faces}: ${val}">
      <span class="azar-die-type">D${faces}</span>
      <span class="azar-die-value">${val}</span>
    </div>`;
  }

  btn.addEventListener('click', () => {
    const azarRandom = (window as any).azarRandom as () => number;
    const qty    = parseInt(qtyInput.value);
    const type   = typeSelect.value;
    const isD6   = type === '6';
    const faces  = type === 'custom' ? null : parseInt(type);
    const minV   = type === 'custom' ? parseInt(minInput.value)  : 1;
    const maxV   = type === 'custom' ? parseInt(maxInput.value)  : (faces ?? 6);

    const results: number[] = Array.from({ length: qty },
      () => minV + Math.floor(azarRandom() * (maxV - minV + 1)));

    const total = results.reduce((a, b) => a + b, 0);
    sumEl.textContent = String(total);
    sumEl.style.color = isD6 ? 'var(--color-gold)' : 'var(--color-amber)';

    resultDiv.innerHTML = results
      .map((v, i) => isD6 ? buildD6(v, i * 70) : buildDPoly(v, faces ?? maxV, i * 70))
      .join('');
  });
</script>
