---
// Tool: Lanzamiento de Dados
---

<div id="tool-dados"
     class="spotlight-card relative bg-card border border-gold/10 rounded-sm p-8 md:p-10 overflow-hidden transition-all duration-300 hover:border-gold/30 hover:-translate-y-1">

  <div class="flex items-start justify-between mb-8">
    <div>
      <div class="font-mono text-[10px] tracking-[0.2em] uppercase text-muted mb-2">02 — Dados</div>
      <h3 class="font-display text-4xl md:text-5xl text-prim tracking-wide">DADOS</h3>
      <p class="font-serif italic text-sec text-lg mt-1">Lanzamiento personalizado</p>
    </div>
    <div id="dado-icon" class="text-5xl select-none transition-all duration-200">⚄</div>
  </div>

  <!-- Options -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">
        Cantidad de dados: <span id="dados-qty-val" class="text-gold">2</span>
      </label>
      <input type="range" id="dados-qty" min="1" max="20" value="2" class="w-full" />
    </div>
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">
        Tipo de dado
      </label>
      <select id="dados-type"
              class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-4 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200">
        <option value="6">D6 — Estándar (1-6)</option>
        <option value="4">D4 — Tetraedro (1-4)</option>
        <option value="8">D8 — Octaedro (1-8)</option>
        <option value="10">D10 — Decaedro (1-10)</option>
        <option value="12">D12 — Dodecaedro (1-12)</option>
        <option value="20">D20 — Icosaedro (1-20)</option>
        <option value="100">D100 — Percentil (1-100)</option>
        <option value="custom">Personalizado</option>
      </select>
    </div>
  </div>

  <!-- Custom range (shown only when custom selected) -->
  <div id="custom-range-row" class="hidden grid grid-cols-2 gap-4 mb-6">
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">Mínimo</label>
      <input type="number" id="dados-min" value="1" min="-999" max="999"
             class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-4 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200" />
    </div>
    <div>
      <label class="font-mono text-[10px] tracking-[0.15em] uppercase text-muted block mb-2">Máximo</label>
      <input type="number" id="dados-max" value="100" min="-999" max="9999"
             class="w-full bg-elevated border border-gold/10 text-prim font-mono text-sm px-4 py-2.5 rounded-sm outline-none focus:border-gold/35 transition-colors duration-200" />
    </div>
  </div>

  <!-- Results display -->
  <div id="dados-result"
       class="min-h-[100px] bg-void/60 border border-gold/8 rounded-sm p-5 mb-4 transition-all duration-300">
    <div class="flex items-center justify-center h-full">
      <span class="font-mono text-xs text-muted">Lanza los dados para ver los resultados</span>
    </div>
  </div>

  <!-- Sum display -->
  <div class="flex items-center justify-between bg-elevated/50 border border-gold/8 rounded-sm px-5 py-3 mb-6">
    <span class="font-mono text-[10px] tracking-widest uppercase text-muted">Total</span>
    <span id="dados-sum" class="font-display text-3xl text-gold">—</span>
  </div>

  <button id="dados-btn" data-hover
          class="w-full font-mono text-xs tracking-[0.15em] uppercase bg-gold text-void py-4 rounded-sm font-medium hover:bg-amber transition-colors duration-200 active:scale-[0.99]"
          onmouseenter="this.style.boxShadow='0 0 25px rgba(212,168,67,.3)'"
          onmouseleave="this.style.boxShadow='none'">
    ◈ Lanzar Dados
  </button>
</div>

<script>
  const DICE_FACES = ['⚀','⚁','⚂','⚃','⚄','⚅'];
  const qtyInput  = document.getElementById('dados-qty') as HTMLInputElement;
  const qtyVal    = document.getElementById('dados-qty-val')!;
  const typeSelect= document.getElementById('dados-type') as HTMLSelectElement;
  const customRow = document.getElementById('custom-range-row')!;
  const minInput  = document.getElementById('dados-min') as HTMLInputElement;
  const maxInput  = document.getElementById('dados-max') as HTMLInputElement;
  const resultDiv = document.getElementById('dados-result')!;
  const sumEl     = document.getElementById('dados-sum')!;
  const btn       = document.getElementById('dados-btn')!;
  const icon      = document.getElementById('dado-icon')!;

  qtyInput.addEventListener('input', () => { qtyVal.textContent = qtyInput.value; });

  typeSelect.addEventListener('change', () => {
    customRow.classList.toggle('hidden', typeSelect.value !== 'custom');
    customRow.classList.toggle('grid',   typeSelect.value === 'custom');
  });

  btn.addEventListener('click', () => {
    const azarRandom = (window as any).azarRandom as () => number;
    const qty   = parseInt(qtyInput.value);
    const faces = typeSelect.value === 'custom'
      ? null
      : parseInt(typeSelect.value);
    const min   = typeSelect.value === 'custom' ? parseInt(minInput.value) : 1;
    const max   = typeSelect.value === 'custom' ? parseInt(maxInput.value) : (faces ?? 6);

    // Animate header icon
    icon.classList.add('animate-dice-shake');
    setTimeout(() => icon.classList.remove('animate-dice-shake'), 700);

    const results: number[] = [];
    for (let i = 0; i < qty; i++) {
      results.push(min + Math.floor(azarRandom() * (max - min + 1)));
    }

    const sum = results.reduce((a, b) => a + b, 0);
    sumEl.textContent = sum.toString();

    const isD6 = faces === 6;
    resultDiv.innerHTML = `
      <div class="flex flex-wrap gap-3 justify-center">
        ${results.map((v, i) => `
          <div class="flex flex-col items-center gap-1 animate-float-up" style="animation-delay:${i*60}ms">
            <div class="font-display text-3xl text-amber" style="text-shadow:0 0 15px rgba(245,200,66,.4)">
              ${isD6 ? DICE_FACES[v - 1] : v}
            </div>
            ${qty > 1 ? `<div class="font-mono text-[9px] text-muted">${isD6 ? v : ''}</div>` : ''}
          </div>
        `).join('')}
      </div>`;

    document.getElementById('last-random')!.textContent = sum.toString();
  });

  // Spotlight
  const card = document.getElementById('tool-dados')!;
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
    card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100).toFixed(1) + '%');
  });
</script>
