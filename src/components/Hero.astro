---
// Hero / Landing section — no props needed
---

<!-- ─── HERO ──────────────────────────────────────────────── -->
<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 sm:px-6">

  <!-- Background decorative rings (hidden on small screens) -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none hidden sm:flex">
    <div class="w-[min(600px,90vw)] h-[min(600px,90vw)] rounded-full border border-gold/5 animate-spin-slow"></div>
    <div class="absolute w-[min(400px,65vw)] h-[min(400px,65vw)] rounded-full border border-gold/8" style="animation: spin-slow 14s linear infinite reverse;"></div>
    <div class="absolute w-[min(200px,40vw)] h-[min(200px,40vw)] rounded-full border border-amber/10"></div>
  </div>

  <!-- Glowing orb -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(212,168,67,.07) 0%, transparent 70%); filter: blur(40px);"></div>

  <!-- Nav -->
  <nav class="absolute top-0 left-0 right-0 flex items-center justify-between px-4 sm:px-8 py-5 z-10">
    <div class="flex items-center gap-2 sm:gap-3">
      <span class="text-xl sm:text-2xl">⟆</span>
      <span class="font-display text-lg sm:text-xl tracking-widest text-gold uppercase">Azar</span>
    </div>
    <div class="hidden md:flex items-center gap-8">
      <a href="#tools"   class="font-mono text-xs tracking-widest uppercase text-muted hover:text-gold transition-colors duration-200" data-hover>Juegos</a>
      <a href="#entropy" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-gold transition-colors duration-200" data-hover>Entropía</a>
    </div>
    <!-- Intentionally no right element to avoid overlapping entropy HUD -->
  </nav>

  <!-- Main headline -->
  <div class="relative text-center z-10 max-w-5xl">
    <div class="animate-float-up">
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-amber/70 border border-amber/20 px-4 py-1.5 rounded-sm inline-block mb-8">
        Entropía del Cursor · Aleatorio Real
      </span>
    </div>

    <h1 class="font-display text-[clamp(5rem,15vw,14rem)] leading-none tracking-wider text-prim animate-float-up delay-100">
      AZAR
    </h1>

    <p class="font-serif text-[clamp(1.1rem,2.5vw,1.6rem)] font-light italic text-sec mt-4 mb-2 animate-float-up delay-200">
      Herramientas de aleatoriedad potenciadas por tu movimiento
    </p>
    <p class="font-mono text-xs text-muted max-w-xl mx-auto leading-relaxed animate-float-up delay-300">
      Cada cálculo aleatorio usa entropía colectada de tu ratón en tiempo real.<br/>
      Sin servidores. Sin backend. Todo en tu navegador.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mt-10 sm:mt-12 animate-float-up delay-400">
      <a href="#tools" data-hover
         class="inline-flex items-center gap-3 font-mono text-xs tracking-widest uppercase bg-gold text-void px-6 sm:px-8 py-4 rounded-sm font-medium hover:bg-amber transition-colors duration-200 w-full sm:w-auto justify-center"
         style="transition: background .2s, box-shadow .3s;"
         onmouseenter="this.style.boxShadow='0 0 30px rgba(212,168,67,.35)'"
         onmouseleave="this.style.boxShadow='0 0 0 0 rgba(212,168,67,0)'">
        Ver los juegos
        <span>↓</span>
      </a>
      <a href="#entropy" data-hover
         class="inline-flex items-center gap-3 font-mono text-xs tracking-widest uppercase border border-gold/15 text-sec px-6 sm:px-8 py-4 rounded-sm hover:border-gold/40 hover:text-gold transition-colors duration-200 w-full sm:w-auto justify-center">
        ¿Cómo funciona?
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-fade delay-400">
    <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-muted">Interactúa</span>
    <div class="w-px h-8 bg-gradient-to-b from-gold/40 to-transparent"></div>
  </div>
</section>

<!-- ─── ENTROPY EXPLANATION ────────────────────────────────── -->
<section id="entropy" class="py-16 sm:py-24 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">

    <!-- ── Section label ── -->
    <div class="flex items-center gap-4 mb-10">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/15 to-transparent"></div>
      <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-muted">El Motor</span>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/15 to-transparent"></div>
    </div>

    <!-- ── Centered title spanning full width ── -->
    <div class="text-center mb-12">
      <h2 class="font-display text-[clamp(3rem,8vw,7rem)] leading-none text-prim">
        ENTROPÍA <span class="text-gold">HUMANA</span>
      </h2>
    </div>

    <!-- ── Two equal columns ── -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">

      <!-- Left: description + quote + live seed display -->
      <div class="flex flex-col justify-center gap-6">
        <p class="font-serif text-lg font-light text-sec leading-relaxed">
          Mientras interactúas, capturamos la impredecibilidad de tus acciones (movimientos,
          toques, micropausas y vibraciones) y la mezclamos criptográficamente con el ruido
          térmico de tu dispositivo.
          <strong>Caos humano + Entropía digital.</strong>
        </p>

        <blockquote class="border-l-2 border-gold/30 pl-5">
          <p class="font-serif text-base italic text-muted leading-relaxed">
            "La verdadera aleatoriedad nace del caos.<br/>Tu interacción es el caos."
          </p>
        </blockquote>

        <!-- Live seed preview -->
        <div class="bg-card/60 border border-gold/10 rounded-sm p-5">
          <div class="font-mono text-[10px] tracking-widest uppercase text-muted mb-3">
            Semilla activa
          </div>
          <div id="hero-seed-display"
               class="font-mono text-xs text-gold/80 leading-relaxed break-all"
               style="font-size: 11px; letter-spacing: .05em;">
            Esperando interacción...
          </div>
          <div class="mt-3 flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-muted" id="hero-seed-dot"></div>
            <span class="font-mono text-[9px] text-muted tracking-widest uppercase"
                  id="hero-seed-status">Sin actividad</span>
          </div>
        </div>
      </div>

      <!-- Right: live entropy visualizer card (same height via flex) -->
      <div class="flex flex-col">
        <div class="bg-card border border-gold/10 rounded-sm p-6 relative overflow-hidden flex-1 flex flex-col">
          <div class="absolute inset-0 pointer-events-none"
               style="background: radial-gradient(ellipse at 50% 0%, rgba(212,168,67,.05) 0%, transparent 60%);">
          </div>

          <div class="font-mono text-[10px] tracking-widest uppercase text-muted mb-4 relative z-10">
            Pool de Entropía — En Vivo
          </div>

          <!-- Entropy pool visual grid -->
          <div id="entropy-grid" class="grid gap-1 mb-5 relative z-10"
               style="grid-template-columns: repeat(16, 1fr);">
            {Array.from({length: 64}, (_, i) => (
              <div class="entropy-cell h-2 rounded-full bg-elevated transition-all duration-300" data-idx={i}></div>
            ))}
          </div>

          <!-- Signal bar -->
          <div class="space-y-2 relative z-10 mt-auto">
            <div class="flex justify-between items-baseline">
              <span class="font-mono text-[10px] text-muted">Señal de entropía</span>
              <span id="hero-entropy-val" class="font-display text-3xl text-gold">8%</span>
            </div>
            <div class="h-1 bg-elevated rounded-full overflow-hidden">
              <div id="hero-entropy-fill" class="h-full rounded-full transition-none"
                   style="width:8%; background: linear-gradient(90deg, var(--color-violet), var(--color-gold), var(--color-amber));"></div>
            </div>
            <div class="flex justify-between font-mono text-[9px] text-muted">
              <span>Reposo</span>
              <span id="entropy-state">Interactúa →</span>
              <span>Activo</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── 4-col feature grid (symmetric, full width) ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { icon: '⟆', label: 'Movimiento XY',   desc: 'Coordenadas y aceleración' },
        { icon: '📱', label: 'Sensores Móviles',desc: 'Acelerómetro y taps exactos' },
        { icon: '〰', label: 'Ruido Térmico',   desc: 'Fluctuaciones de CPU en reposo' },
        { icon: '🛡️', label: 'Red de Seguridad',desc: 'Fusión con entropía nativa' },
      ].map(item => (
        <div class="flex items-start gap-4 p-5 bg-card/50 border border-gold/8 rounded-sm">
          <span class="text-gold font-mono text-xl shrink-0 mt-0.5">{item.icon}</span>
          <div>
            <div class="font-mono text-[10px] tracking-widest uppercase text-prim mb-1">{item.label}</div>
            <div class="font-mono text-[10px] text-muted leading-relaxed">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>


<script>
  // Hero entropy visualizer — reads live signal every frame
  const bar   = document.getElementById('entropy-bar')!;
  const fill  = document.getElementById('hero-entropy-fill')!;
  const val   = document.getElementById('hero-entropy-val')!;
  const st    = document.getElementById('entropy-state')!;
  const cells = document.querySelectorAll<HTMLElement>('.entropy-cell');
  
  const seedDisplay = document.getElementById('hero-seed-display')!;
  const seedStatus  = document.getElementById('hero-seed-status')!;
  const seedDot     = document.getElementById('hero-seed-dot')!;

  let cellFrame = 0;
  function heroLoop() {
    const sig = (window as any).azarSignal as number ?? 0.12;
    const pct = sig * 100;

    fill.style.width = pct.toFixed(2) + '%';
    val.textContent  = pct.toFixed(1) + '%';

    if (pct > 65)      st.textContent = '⚡ Activo';
    else if (pct > 30) st.textContent = 'Detectando...';
    else               st.textContent = 'Interactúa →';

    // Update pool cells and seed display at 6fps (every ~10 frames)
    cellFrame++;
    if (cellFrame % 10 === 0) {
      const pool = (window as any).azarPool as Uint32Array;
      if (pool) {
        // Update grid cells
        cells.forEach((cell, i) => {
          const v = (pool[i % pool.length] >>> 0) / 4294967296;
          cell.style.opacity    = (0.1 + v * 0.9).toFixed(2);
          cell.style.background = v > 0.7 ? 'var(--color-gold)'
            : v > 0.4 ? 'var(--color-violet)' : 'var(--color-elevated)';
        });

        // Update the active seed text
        let hexString = '';
        for (let i = 0; i < 4; i++) {
          hexString += (pool[i] >>> 0).toString(16).padStart(8, '0');
        }
        seedDisplay.textContent = '0x' + hexString.toUpperCase();

        // Update the status below the seed
        if (pct > 20) {
          seedStatus.textContent = 'RECIBIENDO ENTROPÍA';
          seedStatus.style.color = 'var(--color-gold)';
          seedDot.style.background = 'var(--color-amber)';
          seedDot.style.boxShadow = '0 0 8px rgba(245,200,66,0.6)';
        } else {
          seedStatus.textContent = 'REPOSO (RUIDO TÉRMICO)';
          seedStatus.style.color = 'var(--color-muted)';
          seedDot.style.background = 'var(--color-muted)';
          seedDot.style.boxShadow = 'none';
        }
      }
    }

    requestAnimationFrame(heroLoop);
  }
  requestAnimationFrame(heroLoop);
</script>
