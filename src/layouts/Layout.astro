---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Azar — Juegos del Azar',
  description = 'Juegos de aleatoriedad potenciados por entropía real. Sorteos, dados, cartas y más — todo calculado en tu navegador.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080810" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,700;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Bebas+Neue&display=swap" />
  </head>
  <body>

    <!-- Entropy bar top (1px line) -->
    <div id="entropy-bar"></div>

    <!-- Premium entropy HUD badge -->
    <div id="entropy-badge" aria-label="Nivel de entropía en tiempo real">
      <div id="entropy-pulse"></div>
      <div>
        <div id="entropy-label">ENTROPÍA</div>
        <div id="entropy-val">8.0%</div>
        <div id="entropy-hex">0x000000</div>
      </div>
    </div>

    <!-- Custom cursor (desktop only) -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>

    <slot />

    <script>
      // ═══════════════════════════════════════════════════
      //  ENTROPY POOL — for RNG quality (internal, grows silently)
      // ═══════════════════════════════════════════════════
      const POOL_SIZE = 256;
      const pool      = new Uint32Array(POOL_SIZE);
      let poolIdx     = 0;

      try { crypto.getRandomValues(pool); } catch {}

      function xorMix(a: number): number {
        a ^= a << 13; a ^= a >> 17; a ^= a << 5;
        return a >>> 0;
      }

      function feedPool(v: number) {
        pool[poolIdx % POOL_SIZE] = xorMix(pool[poolIdx % POOL_SIZE] ^ (v | 0));
        poolIdx = (poolIdx + 1) % POOL_SIZE;
      }

      // ═══════════════════════════════════════════════════
      //  ENTROPY SIGNAL — the LIVE display value
      //  Decays toward a floor when idle, spikes with activity.
      //  Never reaches 100% and stays there — always fluctuating.
      // ═══════════════════════════════════════════════════
      // ── ENTROPY SIGNAL — live display (decays when idle) ──
      // Model: pure multiplicative decay toward FLOOR.
      //   idle:   signal halves every ~1.4s  (DECAY_K^60 ≈ 0.22)
      //   active: each mousemove pixel adds ~0.45%, fast swipe → +30%+
      // This ensures it moves visibly: high while moving, drops when stopped.
      const FLOOR   = 0.08;    // idle rest (~8%)
      const CEILING = 0.91;    // hard cap (never 100%)
      const DECAY_K = 0.975;   // per-frame multiplier toward floor
      let   signal  = FLOOR;

      function boostSignal(amount: number) {
        signal = Math.min(CEILING, signal + amount);
      }

      let lastRaf  = performance.now();
      let rafCount = 0;
      function rafLoop() {
        const now  = performance.now();
        const diff = now - lastRaf;
        lastRaf    = now;

        // Feed pool from timing jitter (always free entropy for RNG)
        feedPool((diff * 100000) | 0);
        feedPool((now  * 10000)  | 0);

        // Decay: signal approaches FLOOR exponentially
        signal = Math.max(FLOOR, signal * DECAY_K + FLOOR * (1 - DECAY_K));

        rafCount++;
        if (rafCount % 3 === 0) updateHUD();
        requestAnimationFrame(rafLoop);
      }
      requestAnimationFrame(rafLoop);

      // ── Input events ───────────────────────────────────
      document.addEventListener('mousemove', e => {
        const speed = Math.hypot(e.movementX, e.movementY);
        boostSignal(speed * 0.0045);   // fast swipe → big spike
        feedPool((e.movementX * 137 + e.movementY * 59) | 0);
        feedPool((e.clientX ^ (e.clientY << 8)) | 0);
      }, { passive: true });

      document.addEventListener('touchmove', e => {
        const t = e.touches[0];
        boostSignal(0.05);
        feedPool((t.clientX * 17 + t.clientY * 31) | 0);
        feedPool((performance.now() * 100) | 0);
      }, { passive: true });

      document.addEventListener('touchstart', () => {
        boostSignal(0.09);
        feedPool((performance.now() | 0));
      }, { passive: true });

      document.addEventListener('click', e => {
        boostSignal(0.07);
        feedPool((e.clientX * 7 + e.clientY * 11) | 0);
      }, { passive: true });

      if ('DeviceMotionEvent' in window) {
        window.addEventListener('devicemotion', e => {
          const a = e.acceleration;
          if (!a) return;
          const mag = Math.abs(a.x ?? 0) + Math.abs(a.y ?? 0) + Math.abs(a.z ?? 0);
          boostSignal(mag * 0.006);
          feedPool((mag * 1000) | 0);
        }, { passive: true });
      }

      // ── HUD update ─────────────────────────────────────
      // Shows live % + hex slice from pool — looks like real computation
      function updateHUD() {
        const pct    = signal * 100;
        // Live hex from pool — changes every update showing active computation
        const hexVal = ((pool[poolIdx % POOL_SIZE] >>> 0) & 0xFFFFFF)
                         .toString(16).toUpperCase().padStart(6, '0');
        const bar    = document.getElementById('entropy-bar')!;
        const val    = document.getElementById('entropy-val')!;
        const hex    = document.getElementById('entropy-hex');
        const badge  = document.getElementById('entropy-badge')!;
        bar.style.width       = pct.toFixed(2) + '%';
        val.textContent       = pct.toFixed(1) + '%';
        if (hex) hex.textContent = '0x' + hexVal;
        badge.dataset.charged = pct > 40 ? '1' : '0';
      }

      // ── azarRandom: public API ─────────────────────────
      function azarRandom(): number {
        let s = 0;
        const t = (performance.now() * 10000) | 0;
        for (let i = 0; i < 8; i++) s ^= pool[(poolIdx + i) % POOL_SIZE];
        s ^= t; s ^= (t >>> 16);
        s = xorMix(s);
        pool[poolIdx % POOL_SIZE] = s;
        poolIdx = (poolIdx + 1) % POOL_SIZE;
        
        // Convert signed 32-bit integer to unsigned, then divide by 2^32 (4294967296)
        // to normalize the value to a float between 0.0 (inclusive) and 1.0 (exclusive)
        const humanEntropy = (s >>> 0) / 4294967296;
        // Machine entropy from the browser's PRNG [0, 1)
        const machineEntropy = Math.random();
        
        // Blend them securely: modulo 1 addition preserves uniform distribution
        return (humanEntropy + machineEntropy) % 1;
      }

      (window as any).azarRandom = azarRandom;
      (window as any).azarPool   = pool;
      // Expose live signal level for visualizers
      Object.defineProperty(window, 'azarSignal', { get: () => signal });

      // ═══════════════════════════════════════════════════
      //  CURSOR — GPU-accelerated via transform3d
      // ═══════════════════════════════════════════════════
      const dot  = document.getElementById('cursor-dot')!;
      const ring = document.getElementById('cursor-ring')!;
      const isMobile = window.matchMedia('(pointer: coarse)').matches;

      if (dot && ring && !isMobile) {
        document.documentElement.style.cursor = 'none';
        dot.style.display  = 'block';
        ring.style.display = 'block';

        let mx = 0, my = 0; // raw mouse
        let rx = 0, ry = 0; // ring lerp
        let rafId: number;

        document.addEventListener('mousemove', e => {
          mx = e.clientX; my = e.clientY;
          // Dot follows instantly (no lerp)
          dot.style.transform = `translate3d(${mx}px,${my}px,0) translate(-50%,-50%)`;
        }, { passive: true });

        // Ring lerps behind mouse — single RAF loop
        function lerpRing() {
          rx += (mx - rx) * 0.14;
          ry += (my - ry) * 0.14;
          ring.style.transform = `translate3d(${rx}px,${ry}px,0) translate(-50%,-50%)`;
          rafId = requestAnimationFrame(lerpRing);
        }
        lerpRing();

        document.querySelectorAll<HTMLElement>('a, button, [data-hover], input[type="range"]').forEach(el => {
          el.addEventListener('mouseenter', () => ring.classList.add('hovering'));
          el.addEventListener('mouseleave', () => ring.classList.remove('hovering'));
        });
      } else if (dot && ring) {
        // Hide cursor on mobile
        dot.style.display  = 'none';
        ring.style.display = 'none';
      }

      // ═══════════════════════════════════════════════════
      //  SPOTLIGHT — throttled via RAF flag
      // ═══════════════════════════════════════════════════
      let spotlightScheduled = false;
      const spotlightCards = document.querySelectorAll<HTMLElement>('.spotlight-card');

      document.addEventListener('mousemove', e => {
        if (spotlightScheduled) return;
        spotlightScheduled = true;
        requestAnimationFrame(() => {
          spotlightCards.forEach(card => {
            const r = card.getBoundingClientRect();
            // Only update if mouse is near the card
            if (e.clientX >= r.left - 100 && e.clientX <= r.right + 100 &&
                e.clientY >= r.top  - 100 && e.clientY <= r.bottom + 100) {
              card.style.setProperty('--mx', ((e.clientX - r.left) / r.width  * 100).toFixed(1) + '%');
              card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100).toFixed(1) + '%');
            }
          });
          spotlightScheduled = false;
        });
      }, { passive: true });
    </script>
  </body>
</html>
